---
import { APP_NAME, ACCENT_COLOR } from '../config';

interface Props {
  title?: string;
}
const { title = APP_NAME } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>
  <div class="wave wave-1"></div>
  <div class="wave wave-2"></div>
  <div class="wave wave-3"></div>
  
  <div class="dot dot-1"></div>
  <div class="dot dot-2"></div>
  <div class="dot dot-3"></div>
  <div class="dot dot-4"></div>
  <div class="dot dot-5"></div>
  <div class="dot dot-6"></div>
  <div class="dot dot-7"></div>
  <div class="dot dot-8"></div>
  <div class="dot dot-9"></div>
  <div class="dot dot-10"></div>
  
  <main class="main-content">
    <slot />
  </main>
  
  <footer>
    <p>
      Veil &nbsp;·&nbsp;
      Powered by
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" style="vertical-align: middle; margin: 0 4px;">
        <path d="M16.5 9.5L19.5 12.5L16.5 15.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        <path d="M7.5 9.5L4.5 12.5L7.5 15.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        <path d="M14 7L10 18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
      </svg>
      <a href="https://developers.cloudflare.com/workers/" target="_blank">Cloudflare Workers</a>
      &nbsp;·&nbsp;
      <a href="https://github.com/anomalyco/veil" target="_blank">GitHub</a>
    </p>
  </footer>
</body>
</html>

<style is:global define:vars={{ accentColor: ACCENT_COLOR }}>
  :root {
    --accent:       var(--accentColor);
    --accent-light: color-mix(in srgb, var(--accentColor) 80%, white);
    --accent-dark:  color-mix(in srgb, var(--accentColor) 80%, black);
    --bg-primary:   #0d0d0d;
    --bg-secondary: #1a1a1a;
    --bg-tertiary:  #2a2a2a;
    --text-primary: #ffffff;
    --text-secondary: #e0e0e0;
    --text-muted:   #a0a0a0;
    --border-color: #3a3a3a;
    --radius-sm:    4px;
    --radius-md:    8px;
    --radius-lg:    12px;
    --transition:   0.2s ease;
    --font-sans:    'Inter', -apple-system, sans-serif;
    --font-mono:    'Cascadia Code', 'Fira Code', monospace;
    --shadow-accent: 0 4px 20px color-mix(in srgb, var(--accentColor) 30%, transparent);
  }

  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  body {
    font-family: var(--font-sans);
    background: var(--bg-primary);
    color: var(--text-primary);
    min-height: 100vh;
    line-height: 1.6;
    overflow-x: hidden;
  }

  .main-content {
    position: relative;
    z-index: 1;
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem 1.5rem;
    min-height: calc(100vh - 80px);
  }

  .wave {
    position: fixed;
    border-radius: 50%;
    opacity: 0.04;
    pointer-events: none;
    z-index: -1;
    background: var(--accent);
  }

  .wave-1 {
    width: 800px;
    height: 800px;
    top: -200px;
    right: -200px;
    animation: wave 20s linear infinite;
  }

  .wave-2 {
    width: 600px;
    height: 600px;
    bottom: -150px;
    left: -150px;
    animation: wave 25s linear infinite reverse;
  }

  .wave-3 {
    width: 400px;
    height: 400px;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    animation: wave 30s linear infinite;
  }

  @keyframes wave {
    0% { transform: rotate(0deg) scale(1); }
    50% { transform: rotate(180deg) scale(1.1); }
    100% { transform: rotate(360deg) scale(1); }
  }

  .dot {
    position: fixed;
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--accent);
    opacity: 0.2;
    pointer-events: none;
    z-index: -1;
  }

  .dot-1 { top: 10%; left: 5%; animation: floatDot 6s ease-in-out infinite; }
  .dot-2 { top: 20%; left: 85%; animation: floatDot 7s ease-in-out infinite 0.5s; }
  .dot-3 { top: 40%; left: 15%; animation: floatDot 8s ease-in-out infinite 1s; }
  .dot-4 { top: 50%; left: 90%; animation: floatDot 6s ease-in-out infinite 1.5s; }
  .dot-5 { top: 70%; left: 25%; animation: floatDot 7s ease-in-out infinite 2s; }
  .dot-6 { top: 80%; left: 75%; animation: floatDot 8s ease-in-out infinite 2.5s; }
  .dot-7 { top: 15%; left: 50%; animation: floatDot 6s ease-in-out infinite 3s; }
  .dot-8 { top: 60%; left: 40%; animation: floatDot 7s ease-in-out infinite 3.5s; }
  .dot-9 { top: 35%; left: 70%; animation: floatDot 8s ease-in-out infinite 4s; }
  .dot-10 { top: 85%; left: 55%; animation: floatDot 6s ease-in-out infinite 4.5s; }

  @keyframes floatDot {
    0%, 100% { transform: translateY(0) scale(1); opacity: 0.2; }
    50% { transform: translateY(-20px) scale(1.5); opacity: 0.4; }
  }

  footer {
    position: relative;
    z-index: 1;
    text-align: center;
    padding: 2rem 1rem;
    color: var(--text-muted);
    font-size: 0.875rem;
  }

  footer a {
    color: var(--accent);
    text-decoration: none;
    transition: color var(--transition);
  }

  footer a:hover {
    color: var(--accent-light);
  }

  footer p {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0.25rem;
  }

  code {
    font-family: var(--font-mono);
    font-size: 0.9em;
  }

  button {
    font-family: var(--font-sans);
    cursor: pointer;
    border: none;
    outline: none;
  }

  button:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  input {
    font-family: var(--font-sans);
    outline: none;
  }

  input:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }
</style>
