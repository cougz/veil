</style>

<span id="email-stats-data" data-stats={emailStats} hidden></span>

<script>
  const userMenu = document.getElementById('user-menu-trigger')?.parentElement;
  const userMenuTrigger = document.getElementById('user-menu-trigger');
  const userMenuDropdown = document.getElementById('user-menu-dropdown');

  function positionDropdown() {
    if (!userMenuTrigger || !userMenuDropdown) return;
    const rect = userMenuTrigger.getBoundingClientRect();
    userMenuDropdown.style.top = `${rect.bottom + 4}px`;
    userMenuDropdown.style.left = `${rect.right - 220}px`;
  }

  userMenuTrigger?.addEventListener('click', (e) => {
    e.stopPropagation();
    userMenu?.classList.toggle('open');
    if (userMenu?.classList.contains('open')) positionDropdown();
  });

  document.addEventListener('click', (e) => {
    if (userMenu && !userMenu.contains(e.target as Node)) {
      userMenu.classList.remove('open');
    }
  });

  async function apiFetch(path, method = 'GET', body = null) {
    const opts = {
      method,
      headers: {
        'Content-Type': 'application/json'
      }
    };
    if (body) opts.body = JSON.stringify(body);
    const res = await fetch(path, opts);
    return res;
  }

  let currentSort = { column: null, asc: true };
  let currentFilter = 'all';
  let currentSearch = '';

  function applyFiltersAndSort() {
    const rows = Array.from(document.querySelectorAll('.alias-row'));
    rows.forEach(row => {
      const matchesFilter = currentFilter === 'all' || row.dataset.status === currentFilter;
      const matchesSearch = !currentSearch || row.dataset.address.toLowerCase().includes(currentSearch.toLowerCase());
      row.style.display = (matchesFilter && matchesSearch) ? '' : 'none';
    });
    if (currentSort.column) {
      sortTable(currentSort.column, currentSort.asc);
    }
  }

  function moveIndicator(group: HTMLElement, activeBtn: HTMLElement) {
    const indicator = group.querySelector('.seg-indicator') as HTMLElement;
    if (!indicator || !activeBtn) return;
    const groupRect = group.getBoundingClientRect();
    const btnRect = activeBtn.getBoundingClientRect();
    indicator.style.left = `${btnRect.left - groupRect.left}px`;
    indicator.style.width = `${btnRect.width}px`;
    indicator.style.transform = 'none';
  }

  function initSegGroup(groupId: string, onActivate: (btn: HTMLElement) => void) {
    const group = document.getElementById(groupId);
    if (!group) return;
    const btns = group.querySelectorAll<HTMLElement>('.seg');
    const activeBtn = group.querySelector<HTMLElement>('.seg.active');
    if (activeBtn) moveIndicator(group, activeBtn);
    btns.forEach(btn => {
      btn.addEventListener('click', () => {
        btns.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        moveIndicator(group, btn);
        onActivate(btn);
      });
    });
  }

  initSegGroup('filter-group', (btn) => {
    currentFilter = btn.dataset.filter ?? 'all';
    applyFiltersAndSort();
  });

  const searchInput = document.getElementById('alias-search');
  searchInput.addEventListener('input', (e) => {
    currentSearch = e.target.value;
    applyFiltersAndSort();
  });

  function sortTable(column, asc) {
    const tbody = document.getElementById('alias-tbody');
    const rows = Array.from(tbody.querySelectorAll('.alias-row'));
    
    rows.sort((a, b) => {
      let valA, valB;
      switch (column) {
        case 'address':
          valA = a.dataset.address.toLowerCase();
          valB = b.dataset.address.toLowerCase();
          break;
        case 'first_seen':
          valA = parseInt(a.dataset.firstSeen, 10);
          valB = parseInt(b.dataset.firstSeen, 10);
          break;
        case 'last_seen':
          valA = parseInt(a.dataset.lastSeen, 10);
          valB = parseInt(b.dataset.lastSeen, 10);
          break;
        case 'mail_count':
          valA = parseInt(a.dataset.mailCount, 10);
          valB = parseInt(b.dataset.mailCount, 10);
          break;
        case 'status':
          valA = a.dataset.status;
          valB = b.dataset.status;
          break;
        default:
          return 0;
      }
      if (typeof valA === 'string') {
        return asc ? valA.localeCompare(valB) : valB.localeCompare(valA);
      }
      return asc ? valA - valB : valB - valA;
    });

    rows.forEach(row => tbody.appendChild(row));
  }

  document.querySelectorAll('th.sortable').forEach(th => {
    th.addEventListener('click', () => {
      const column = th.dataset.sort;
      document.querySelectorAll('th.sortable').forEach(h => h.classList.remove('sort-asc', 'sort-desc'));
      
      if (currentSort.column === column) {
        currentSort.asc = !currentSort.asc;
      } else {
        currentSort.column = column;
        currentSort.asc = true;
      }
      
      th.classList.add(currentSort.asc ? 'sort-asc' : 'sort-desc');
      sortTable(column, currentSort.asc);
    });
  });

  function attachToggleListeners() {
    document.querySelectorAll('.btn-toggle').forEach(btn => {
      btn.removeEventListener('click', handleToggle);
      btn.addEventListener('click', handleToggle);
    });
  }

  async function handleToggle(e) {
    const btn = e.currentTarget;
    const address = btn.dataset.address;
    const currentStatus = btn.dataset.status;
    const newStatus = currentStatus === 'active' ? 'blocked' : 'active';

    btn.disabled = true;
    btn.textContent = '...';

    const res = await apiFetch(
      `/api/aliases/${encodeURIComponent(address)}`,
      'PATCH',
      { status: newStatus }
    );

    if (res.ok) {
      const row = document.querySelector(`tr[data-address="${address}"]`);
      row.dataset.status = newStatus;
      btn.dataset.status = newStatus;
      btn.textContent = newStatus === 'active' ? 'Disable' : 'Enable';
      const badge = row.querySelector('.badge');
      badge.className = `badge ${newStatus === 'active' ? 'badge-active' : 'badge-blocked'}`;
      badge.textContent = newStatus === 'active' ? 'Enabled' : 'Disabled';
    } else {
      btn.textContent = currentStatus === 'active' ? 'Disable' : 'Enable';
      alert('Failed to update alias.');
    }
    btn.disabled = false;
  }

  function attachDeleteListeners() {
    document.querySelectorAll('.btn-delete').forEach(btn => {
      btn.removeEventListener('click', handleDelete);
      btn.addEventListener('click', handleDelete);
    });
  }

  async function handleDelete(e) {
    const btn = e.currentTarget;
    const address = btn.dataset.address;
    if (!confirm(`Delete ${address}? This cannot be undone.`)) return;

    btn.disabled = true;
    const res = await apiFetch(
      `/api/aliases/${encodeURIComponent(address)}`,
      'DELETE'
    );

    if (res.ok) {
      document.querySelector(`tr[data-address="${address}"]`)?.remove();
    } else {
      alert('Failed to delete alias.');
      btn.disabled = false;
    }
  }

  attachToggleListeners();
  attachDeleteListeners();

  const emailStats = JSON.parse(document.getElementById('email-stats-data')?.dataset.stats ?? '{}');
  initSegGroup('range-group', (btn) => {
    const range = btn.dataset.range;
    const stats = emailStats[range] ?? { total: 0, forwarded: 0, blocked: 0 };
    document.getElementById('stat-forwarded')!.textContent = stats.forwarded;
    document.getElementById('stat-blocked')!.textContent = stats.blocked;
    document.getElementById('stat-total')!.textContent = stats.total;
  });
</script>
