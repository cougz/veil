---
import Layout from '../layouts/Layout.astro';
import { isAuthenticated } from '../lib/auth';
import { formatDate } from '../lib/dates';

const env = Astro.locals.runtime.env;
const APP_NAME: string        = env.APP_NAME        ?? 'Veil';
const APP_DESCRIPTION: string = env.APP_DESCRIPTION ?? 'Wildcard email aliasing on Cloudflare Workers. Forward, filter, and burn addresses without exposing your inbox.';
const ACCENT_COLOR: string    = env.ACCENT_COLOR    ?? '#6d83f2';
const DOMAIN: string          = env.DOMAIN          ?? 'yourdomain.com';

if (!isAuthenticated(Astro.request, env)) {
  return Astro.redirect('/login', 302);
}

const db = env.DB;
const { results: aliases } = await db
  .prepare('SELECT * FROM aliases ORDER BY last_seen DESC')
  .all();

const total   = aliases.length;
const active  = aliases.filter((a: any) => a.status === 'active').length;
const blocked = aliases.filter((a: any) => a.status === 'blocked').length;
---

<Layout title={APP_NAME} accentColor={ACCENT_COLOR}>
  <section class="hero">
    <h1 class="hero-title">{APP_NAME}</h1>
    <p class="hero-subtitle">
      {APP_DESCRIPTION}
      <br>
      <span class="powered-by">
        Powered by
        <svg viewBox="0 0 50 50" width="18" height="18" fill="currentColor" aria-hidden="true" class="cf-workers-icon">
          <path d="m18.63 37.418-9.645-12.9 9.592-12.533-1.852-2.527L5.917 23.595l-.015 1.808 10.86 14.542z"></path>
          <path d="M21.997 6.503h-3.712l13.387 18.3-13.072 17.7h3.735L35.4 24.81z"></path>
          <path d="M29.175 6.503h-3.758l13.598 18.082-13.598 17.918h3.765l12.908-17.01v-1.808z"></path>
        </svg>
        <a href="https://developers.cloudflare.com/workers/" target="_blank" rel="noopener">Cloudflare Workers</a>
      </span>
    </p>
    <a href="/settings" class="settings-link">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M12 15C13.6569 15 15 13.6569 15 12C15 10.3431 13.6569 9 12 9C10.3431 9 9 10.3431 9 12C9 13.6569 10.3431 15 12 15Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        <path d="M19.4 15C19.2669 15.3016 19.2272 15.6362 19.286 15.9606C19.3448 16.285 19.4995 16.5843 19.73 16.82L19.79 16.88C19.976 17.0657 20.1235 17.2863 20.2241 17.5291C20.3248 17.7719 20.3766 18.0322 20.3766 18.295C20.3766 18.5578 20.3248 18.8181 20.2241 19.0609C20.1235 19.3037 19.976 19.5243 19.79 19.71C19.6043 19.896 19.3837 20.0435 19.1409 20.1441C18.8981 20.2448 18.6378 20.2966 18.375 20.2966C18.1122 20.2966 17.8519 20.2448 17.6091 20.1441C17.3663 20.0435 17.1457 19.896 16.96 19.71L16.9 19.65C16.6643 19.4195 16.365 19.2648 16.0406 19.206C15.7162 19.1472 15.3816 19.1869 15.08 19.32C14.7842 19.4468 14.532 19.6572 14.3543 19.9255C14.1766 20.1938 14.0813 20.5082 14.08 20.83V21C14.08 21.5304 13.8693 22.0391 13.4942 22.4142C13.1191 22.7893 12.6104 23 12.08 23C11.5496 23 11.0409 22.7893 10.6658 22.4142C10.2907 22.0391 10.08 21.5304 10.08 21V20.91C10.0723 20.579 9.96512 20.258 9.77251 19.9887C9.5799 19.7194 9.31074 19.5143 9 19.4C8.69838 19.2669 8.36381 19.2272 8.03941 19.286C7.71502 19.3448 7.41568 19.4995 7.18 19.73L7.12 19.79C6.93425 19.976 6.71368 20.1235 6.47088 20.2241C6.22808 20.3248 5.96783 20.3766 5.705 20.3766C5.44217 20.3766 5.18192 20.3248 4.93912 20.2241C4.69632 20.1235 4.47575 19.976 4.29 19.79C4.10405 19.6043 3.95653 19.3837 3.85588 19.1409C3.75523 18.8981 3.70343 18.6378 3.70343 18.375C3.70343 18.1122 3.75523 17.8519 3.85588 17.6091C3.95653 17.3663 4.10405 17.1457 4.29 16.96L4.35 16.9C4.58054 16.6643 4.73519 16.365 4.794 16.0406C4.85282 15.7162 4.81312 15.3816 4.68 15.08C4.55324 14.7842 4.34276 14.532 4.07447 14.3543C3.80618 14.1766 3.49179 14.0813 3.17 14.08H3C2.46957 14.08 1.96086 13.8693 1.58579 13.4942C1.21071 13.1191 1 12.6104 1 12.08C1 11.5496 1.21071 11.0409 1.58579 10.6658C1.96086 10.2907 2.46957 10.08 3 10.08H3.09C3.42099 10.0723 3.742 9.96512 4.0113 9.77251C4.28059 9.5799 4.48572 9.31074 4.6 9C4.73312 8.69838 4.77282 8.36381 4.714 8.03941C4.65519 7.71502 4.50054 7.41568 4.27 7.18L4.21 7.12C4.02405 6.93425 3.87653 6.71368 3.77588 6.47088C3.67523 6.22808 3.62343 5.96783 3.62343 5.705C3.62343 5.44217 3.67523 5.18192 3.77588 4.93912C3.87653 4.69632 4.02405 4.47575 4.21 4.29C4.39575 4.10405 4.61632 3.95653 4.85912 3.85588C5.10192 3.75523 5.36217 3.70343 5.625 3.70343C5.88783 3.70343 6.14808 3.75523 6.39088 3.85588C6.63368 3.95653 6.85425 4.10405 7.04 4.29L7.1 4.35C7.33568 4.58054 7.63502 4.73519 7.95941 4.794C8.28381 4.85282 8.61838 4.81312 8.92 4.68H9C9.29577 4.55324 9.54802 4.34276 9.72569 4.07447C9.90337 3.80618 9.99872 3.49179 10 3.17V3C10 2.46957 10.2107 1.96086 10.5858 1.58579C10.9609 1.21071 11.4696 1 12 1C12.5304 1 13.0391 1.21071 13.4142 1.58579C13.7893 1.96086 14 2.46957 14 3V3.09C14.0013 3.41179 14.0966 3.72618 14.2743 3.99447C14.452 4.26276 14.7042 4.47324 15 4.6C15.3016 4.73312 15.6362 4.77282 15.9606 4.714C16.285 4.65519 16.5843 4.50054 16.82 4.27L16.88 4.21C17.0657 4.02405 17.2863 3.87653 17.5291 3.77588C17.7719 3.67523 18.0322 3.62343 18.295 3.62343C18.5578 3.62343 18.8181 3.67523 19.0609 3.77588C19.3037 3.87653 19.5243 4.02405 19.71 4.21C19.896 4.39575 20.0435 4.61632 20.1441 4.85912C20.2448 5.10192 20.2966 5.36217 20.2966 5.625C20.2966 5.88783 20.2448 6.14808 20.1441 6.39088C20.0435 6.63368 19.896 6.85425 19.71 7.04L19.65 7.1C19.4195 7.33568 19.2648 7.63502 19.206 7.95941C19.1472 8.28381 19.1869 8.61838 19.32 8.92V9C19.4468 9.29577 19.6572 9.54802 19.9255 9.72569C20.1938 9.90337 20.5082 9.99872 20.83 10H21C21.5304 10 22.0391 10.2107 22.4142 10.5858C22.7893 10.9609 23 11.4696 23 12C23 12.5304 22.7893 13.0391 22.4142 13.4142C22.0391 13.7893 21.5304 14 21 14H20.91C20.5882 14.0013 20.2738 14.0966 20.0055 14.2743C19.7372 14.452 19.5268 14.7042 19.4 15Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      Settings
    </a>
  </section>

  <div class="stats-row">
    <div class="stat-card">
      <span class="stat-number">{total}</span>
      <span class="stat-label">Total Aliases</span>
    </div>
    <div class="stat-card">
      <span class="stat-number">{active}</span>
      <span class="stat-label">Active</span>
    </div>
    <div class="stat-card">
      <span class="stat-number">{blocked}</span>
      <span class="stat-label">Blocked</span>
    </div>
  </div>

  <div class="options-row">
    <span class="options-label">Filter:</span>
    <div class="pills">
      <button class="pill active" data-filter="all">All <span class="pill-count">{total}</span></button>
      <button class="pill" data-filter="active">Active <span class="pill-count">{active}</span></button>
      <button class="pill" data-filter="blocked">Blocked <span class="pill-count">{blocked}</span></button>
    </div>
  </div>

  <section class="table-section">
    <div class="table-wrapper">
      <table class="alias-table" id="alias-table">
        <thead>
          <tr>
            <th>Address</th>
            <th>First Seen</th>
            <th>Last Seen</th>
            <th>Mails</th>
            <th>Status</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody id="alias-tbody">
          {aliases.map((alias: any) => (
            <tr data-address={alias.address} data-status={alias.status} class="alias-row">
              <td class="alias-address">
                <code>{alias.address}</code>
              </td>
              <td class="alias-date">{formatDate(alias.first_seen)}</td>
              <td class="alias-date">{formatDate(alias.last_seen)}</td>
              <td class="alias-count">{alias.mail_count}</td>
              <td>
                <span class={`badge ${alias.status === 'active' ? 'badge-active' : 'badge-blocked'}`}>
                  {alias.status}
                </span>
              </td>
              <td class="alias-actions">
                <button class="btn-sm btn-toggle" data-address={alias.address} data-status={alias.status}>
                  {alias.status === 'active' ? 'Disable' : 'Enable'}
                </button>
                <button class="btn-sm btn-delete btn-danger" data-address={alias.address}>
                  Delete
                </button>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
      {aliases.length === 0 && (
        <div class="empty-state">
          No aliases yet. Send an email to any address @${DOMAIN} to get started.
        </div>
      )}
    </div>
  </section>
</Layout>

<style>
  .hero {
    text-align: center;
    padding: 80px 0 40px;
    max-width: 680px;
    width: 100%;
    margin: 0 auto;
  }

  .hero-title {
    font-size: 2.8rem;
    font-weight: 700;
    line-height: 1.15;
    margin-bottom: 16px;
    background: linear-gradient(135deg, #ffffff 0%, var(--accent) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-subtitle {
    font-size: 1rem;
    color: var(--text-secondary);
    line-height: 1.6;
    max-width: 480px;
    margin: 0 auto;
  }

  .powered-by {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: 0.85em;
    color: var(--text-muted);
    margin-top: 8px;
  }

  .powered-by svg {
    color: var(--accent);
    vertical-align: text-bottom;
  }

  .powered-by a {
    color: var(--accent);
    font-weight: 500;
    text-decoration: none;
    transition: color var(--transition);
  }

  .powered-by a:hover {
    color: var(--accent-light);
  }

  .settings-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--text-muted);
    text-decoration: none;
    font-size: 0.875rem;
    transition: color var(--transition);
  }

  .settings-link:hover {
    color: var(--accent);
  }

  .stats-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    margin-bottom: 2rem;
  }

  @media (max-width: 600px) {
    .stats-row {
      grid-template-columns: 1fr;
    }
  }

  .stat-card {
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    text-align: center;
    transition: all var(--transition);
  }

  .stat-card:hover {
    border-color: var(--accent);
    box-shadow: var(--shadow-accent);
  }

  .stat-number {
    display: block;
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 0.25rem;
  }

  .stat-label {
    color: var(--text-muted);
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .options-row {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
  }

  .options-label {
    color: var(--text-muted);
    font-size: 0.875rem;
    font-weight: 500;
  }

  .pills {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .pill {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    background: transparent;
    border: 1px solid var(--border-color);
    color: var(--text-secondary);
    padding: 0.5rem 1rem;
    border-radius: 50px;
    font-size: 0.875rem;
    transition: all var(--transition);
  }

  .pill:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  .pill.active {
    background: var(--accent);
    border-color: var(--accent);
    color: white;
  }

  .pill-count {
    background: color-mix(in srgb, var(--text-primary) 20%, transparent);
    padding: 0.125rem 0.5rem;
    border-radius: 50px;
    font-size: 0.75rem;
    font-weight: 600;
  }

  .pill.active .pill-count {
    background: color-mix(in srgb, white 20%, transparent);
  }

  .table-section {
    margin-bottom: 2rem;
  }

  .table-wrapper {
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    overflow: hidden;
    overflow-x: auto;
  }

  .alias-table {
    width: 100%;
    border-collapse: collapse;
    min-width: 700px;
  }

  .alias-table th {
    background: var(--bg-tertiary);
    color: var(--text-muted);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 1rem 1.25rem;
    text-align: left;
    border-bottom: 1px solid var(--border-color);
  }

  .alias-table td {
    padding: 1rem 1.25rem;
    border-bottom: 1px solid var(--border-color);
    vertical-align: middle;
  }

  .alias-row {
    transition: background var(--transition);
  }

  .alias-row:hover {
    background: var(--bg-tertiary);
  }

  .alias-row:last-child td {
    border-bottom: none;
  }

  .alias-address code {
    color: var(--text-primary);
    font-weight: 500;
  }

  .alias-date {
    color: var(--text-muted);
    font-size: 0.9rem;
  }

  .alias-count {
    font-weight: 600;
    color: var(--text-secondary);
  }

  .badge {
    display: inline-flex;
    align-items: center;
    padding: 0.25rem 0.75rem;
    border-radius: 50px;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .badge-active {
    background: color-mix(in srgb, #22c55e 15%, transparent);
    color: #4ade80;
    border: 1px solid color-mix(in srgb, #22c55e 30%, transparent);
  }

  .badge-blocked {
    background: color-mix(in srgb, #ef4444 15%, transparent);
    color: #f87171;
    border: 1px solid color-mix(in srgb, #ef4444 30%, transparent);
  }

  .alias-actions {
    display: flex;
    gap: 0.5rem;
  }

  .btn-sm {
    background: transparent;
    border: 1px solid var(--border-color);
    color: var(--text-secondary);
    padding: 0.4rem 0.75rem;
    border-radius: var(--radius-sm);
    font-size: 0.8rem;
    font-weight: 500;
    transition: all var(--transition);
    white-space: nowrap;
  }

  .btn-sm:hover:not(:disabled) {
    border-color: var(--accent);
    color: var(--accent);
  }

  .btn-sm:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .btn-toggle:hover:not(:disabled) {
    background: color-mix(in srgb, var(--accent) 10%, transparent);
  }

  .btn-danger:hover:not(:disabled) {
    border-color: #ef4444;
    color: #f87171;
    background: color-mix(in srgb, #ef4444 10%, transparent);
  }

  .empty-state {
    text-align: center;
    padding: 3rem 1rem;
    color: var(--text-muted);
    font-size: 1rem;
  }

  @media (max-width: 768px) {
    .hero {
      padding: 56px 0 32px;
    }

    .hero-title {
      font-size: 2rem;
    }

    .hero-subtitle {
      font-size: 0.95rem;
    }

    .stat-number {
      font-size: 2rem;
    }

    .search-bar {
      flex-wrap: wrap;
    }

    .search-btn {
      width: 100%;
      justify-content: center;
    }
  }

  @media (max-width: 600px) {
    .hero {
      padding: 40px 0 24px;
    }

    .hero-title {
      font-size: 1.75rem;
    }
  }
</style>

<script define:vars={{ apiToken: Astro.locals.runtime.env.API_TOKEN }}>
  async function apiFetch(path, method = 'GET', body = null) {
    const opts = {
      method,
      headers: {
        'Content-Type': 'application/json',
        'Authorization': `Bearer ${apiToken}`
      }
    };
    if (body) opts.body = JSON.stringify(body);
    const res = await fetch(path, opts);
    return res;
  }

  document.querySelectorAll('.pill[data-filter]').forEach(pill => {
    pill.addEventListener('click', () => {
      document.querySelectorAll('.pill[data-filter]').forEach(p => p.classList.remove('active'));
      pill.classList.add('active');
      const filter = pill.dataset.filter;
      document.querySelectorAll('.alias-row').forEach(row => {
        if (filter === 'all' || row.dataset.status === filter) {
          row.style.display = '';
        } else {
          row.style.display = 'none';
        }
      });
    });
  });

  function attachToggleListeners() {
    document.querySelectorAll('.btn-toggle').forEach(btn => {
      btn.removeEventListener('click', handleToggle);
      btn.addEventListener('click', handleToggle);
    });
  }

  async function handleToggle(e) {
    const btn = e.currentTarget;
    const address = btn.dataset.address;
    const currentStatus = btn.dataset.status;
    const newStatus = currentStatus === 'active' ? 'blocked' : 'active';

    btn.disabled = true;
    btn.textContent = '...';

    const res = await apiFetch(
      `/api/aliases/${encodeURIComponent(address)}`,
      'PATCH',
      { status: newStatus }
    );

    if (res.ok) {
      const row = document.querySelector(`tr[data-address="${address}"]`);
      row.dataset.status = newStatus;
      btn.dataset.status = newStatus;
      btn.textContent = newStatus === 'active' ? 'Disable' : 'Enable';
      const badge = row.querySelector('.badge');
      badge.className = `badge ${newStatus === 'active' ? 'badge-active' : 'badge-blocked'}`;
      badge.textContent = newStatus;
    } else {
      btn.textContent = currentStatus === 'active' ? 'Disable' : 'Enable';
      alert('Failed to update alias.');
    }
    btn.disabled = false;
  }

  function attachDeleteListeners() {
    document.querySelectorAll('.btn-delete').forEach(btn => {
      btn.removeEventListener('click', handleDelete);
      btn.addEventListener('click', handleDelete);
    });
  }

  async function handleDelete(e) {
    const btn = e.currentTarget;
    const address = btn.dataset.address;
    if (!confirm(`Delete ${address}? This cannot be undone.`)) return;

    btn.disabled = true;
    const res = await apiFetch(
      `/api/aliases/${encodeURIComponent(address)}`,
      'DELETE'
    );

    if (res.ok) {
      document.querySelector(`tr[data-address="${address}"]`)?.remove();
    } else {
      alert('Failed to delete alias.');
      btn.disabled = false;
    }
  }

  attachToggleListeners();
  attachDeleteListeners();
</script>
