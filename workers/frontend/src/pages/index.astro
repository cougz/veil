---
import Layout from '../layouts/Layout.astro';
import { APP_NAME, APP_DESCRIPTION, DOMAIN, MODE } from '../config';
import { isAuthenticated, clearSessionCookie } from '../lib/auth';
import { formatDate } from '../lib/dates';

if (!isAuthenticated(Astro.request, Astro.locals.runtime.env)) {
  return Astro.redirect('/login', 302);
}

const db = Astro.locals.runtime.env.DB;
const page = 1;
const limit = 100;
const offset = (page - 1) * limit;

const { results: aliases } = await db
  .prepare('SELECT * FROM aliases ORDER BY last_seen DESC LIMIT ? OFFSET ?')
  .bind(limit, offset)
  .all();

const countResult = await db
  .prepare('SELECT COUNT(*) as total FROM aliases')
  .first();
const totalCount = (countResult as any)?.total ?? 0;

const activeResult = await db
  .prepare('SELECT COUNT(*) as count FROM aliases WHERE status = ?')
  .bind('active')
  .first();
const activeCount = (activeResult as any)?.count ?? 0;

const blockedResult = await db
  .prepare('SELECT COUNT(*) as count FROM aliases WHERE status = ?')
  .bind('blocked')
  .first();
const blockedCount = (blockedResult as any)?.count ?? 0;

const hasMore = aliases.length === limit;
---

<Layout>
  <section class="hero">
    <h1 class="hero-title">{APP_NAME}</h1>
    <p class="hero-subtitle">{APP_DESCRIPTION}</p>
    <div class="mode-badge" data-mode={MODE}>
      {MODE === 'catchall' ? 'Catch-All Mode' : 'Specific Mode'}
    </div>
  </section>

  <div class="stats-row">
    <div class="stat-card">
      <span class="stat-number">{totalCount}</span>
      <span class="stat-label">Total Aliases</span>
    </div>
    <div class="stat-card">
      <span class="stat-number">{activeCount}</span>
      <span class="stat-label">Active</span>
    </div>
    <div class="stat-card">
      <span class="stat-number">{blockedCount}</span>
      <span class="stat-label">Blocked</span>
    </div>
  </div>

  <div class="actions-row">
    {MODE === 'specific' && (
      <div class="add-section">
        <div class="search-bar">
          <svg class="search-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <circle cx="11" cy="11" r="8" stroke="currentColor" stroke-width="2"/>
            <path d="M21 21l-4.35-4.35" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          </svg>
          <input
            type="text"
            id="new-alias-input"
            class="search-input"
            placeholder={`e.g. netflix@${DOMAIN}`}
            autocomplete="off"
            spellcheck="false"
          />
          <input
            type="date"
            id="expires-input"
            class="expires-input"
            title="Optional expiration date"
          />
          <button class="search-btn" id="add-alias-btn">
            <span class="spinner" id="add-spinner"></span>
            <span id="add-label">Add Alias</span>
          </button>
        </div>
        <div class="error-banner" id="add-error"></div>
      </div>
    )}
    <div class="export-section">
      <a href="/api/aliases/export" class="export-btn" download>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          <polyline points="7,10 12,15 17,10" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          <line x1="12" y1="15" x2="12" y2="3" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        Export CSV
      </a>
      <a href="/logout" class="logout-btn">Logout</a>
    </div>
  </div>

  <div class="options-row">
    <span class="options-label">Filter:</span>
    <div class="pills">
      <button class="pill active" data-filter="all">All <span class="pill-count">{totalCount}</span></button>
      <button class="pill" data-filter="active">Active <span class="pill-count">{activeCount}</span></button>
      <button class="pill" data-filter="blocked">Blocked <span class="pill-count">{blockedCount}</span></button>
    </div>
  </div>

  <section class="table-section">
    <div class="table-wrapper">
      <table class="alias-table" id="alias-table">
        <thead>
          <tr>
            <th>Address</th>
            <th>First Seen</th>
            <th>Last Seen</th>
            <th>Mails</th>
            <th>Expires</th>
            <th>Status</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody id="alias-tbody">
          {aliases.map((alias: any) => (
            <tr data-address={alias.address} data-status={alias.status} class="alias-row">
              <td class="alias-address">
                <code>{alias.address}</code>
                <button class="copy-btn" data-address={alias.address} title="Copy to clipboard">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <rect x="9" y="9" width="13" height="13" rx="2" stroke="currentColor" stroke-width="2"/>
                    <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1" stroke="currentColor" stroke-width="2"/>
                  </svg>
                </button>
              </td>
              <td class="alias-date">{formatDate(alias.first_seen)}</td>
              <td class="alias-date">{formatDate(alias.last_seen)}</td>
              <td class="alias-count">{alias.mail_count}</td>
              <td class="alias-expires">{alias.expires_at ? formatDate(alias.expires_at) : '-'}</td>
              <td>
                <span class={`badge ${alias.status === 'active' ? 'badge-active' : 'badge-blocked'}`}>
                  {alias.status}
                </span>
              </td>
              <td class="alias-actions">
                <button class="btn-sm btn-toggle" data-address={alias.address} data-status={alias.status}>
                  {alias.status === 'active' ? 'Disable' : 'Enable'}
                </button>
                <button class="btn-sm btn-delete btn-danger" data-address={alias.address}>
                  Delete
                </button>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
      {aliases.length === 0 && (
        <div class="empty-state">
          {MODE === 'catchall'
            ? `No aliases yet. Send an email to any address @${DOMAIN} to get started.`
            : 'No aliases yet. Add one above to get started.'}
        </div>
      )}
    </div>
    {hasMore && (
      <div class="load-more-section">
        <button class="load-more-btn" id="load-more-btn">
          <span class="spinner" id="load-more-spinner"></span>
          <span id="load-more-label">Load More</span>
        </button>
      </div>
    )}
  </section>
  
  <div class="toast-container" id="toast-container"></div>
</Layout>

<style>
  .hero {
    text-align: center;
    margin-bottom: 2.5rem;
  }

  .hero-title {
    font-size: 3rem;
    font-weight: 700;
    background: linear-gradient(135deg, var(--text-primary) 0%, var(--accent) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 0.75rem;
  }

  .hero-subtitle {
    color: var(--text-muted);
    font-size: 1.1rem;
    max-width: 600px;
    margin: 0 auto 1.25rem;
    line-height: 1.5;
  }

  .mode-badge {
    display: inline-flex;
    align-items: center;
    padding: 0.5rem 1rem;
    border-radius: 50px;
    font-size: 0.875rem;
    font-weight: 500;
    transition: all var(--transition);
  }

  .mode-badge[data-mode="catchall"] {
    background: var(--accent);
    color: white;
  }

  .mode-badge[data-mode="specific"] {
    background: transparent;
    border: 2px solid var(--accent);
    color: var(--accent);
  }

  .stats-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    margin-bottom: 2rem;
  }

  @media (max-width: 600px) {
    .stats-row {
      grid-template-columns: 1fr;
    }
  }

  .stat-card {
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    text-align: center;
    transition: all var(--transition);
  }

  .stat-card:hover {
    border-color: var(--accent);
    box-shadow: var(--shadow-accent);
  }

  .stat-number {
    display: block;
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 0.25rem;
  }

  .stat-label {
    color: var(--text-muted);
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .actions-row {
    display: flex;
    gap: 1rem;
    margin-bottom: 2rem;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: flex-start;
  }

  .add-section {
    flex: 1;
    min-width: 300px;
  }

  .search-bar {
    display: flex;
    align-items: center;
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    padding: 0.75rem 1rem;
    gap: 0.75rem;
    transition: all var(--transition);
  }

  .search-bar:focus-within {
    border-color: var(--accent);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--accent) 20%, transparent);
  }

  .search-icon {
    color: var(--text-muted);
    flex-shrink: 0;
  }

  .search-input {
    flex: 1;
    background: transparent;
    border: none;
    color: var(--text-primary);
    font-size: 1rem;
    width: 100%;
    min-width: 150px;
  }

  .search-input::placeholder {
    color: var(--text-muted);
  }

  .expires-input {
    background: var(--bg-tertiary);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-sm);
    padding: 0.5rem;
    color: var(--text-primary);
    font-size: 0.875rem;
    width: 130px;
    flex-shrink: 0;
  }

  .expires-input::-webkit-calendar-picker-indicator {
    filter: invert(1);
    cursor: pointer;
  }

  .search-btn {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    background: var(--accent);
    color: white;
    padding: 0.6rem 1.25rem;
    border-radius: var(--radius-md);
    font-size: 0.9rem;
    font-weight: 500;
    transition: all var(--transition);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .search-btn:hover:not(:disabled) {
    background: var(--accent-light);
    transform: translateY(-1px);
  }

  .search-btn:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  .export-section {
    display: flex;
    gap: 0.5rem;
    align-items: center;
  }

  .export-btn, .logout-btn {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    color: var(--text-secondary);
    padding: 0.6rem 1rem;
    border-radius: var(--radius-md);
    font-size: 0.875rem;
    font-weight: 500;
    transition: all var(--transition);
    text-decoration: none;
  }

  .export-btn:hover, .logout-btn:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  .spinner {
    display: none;
    width: 14px;
    height: 14px;
    border: 2px solid transparent;
    border-top-color: white;
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  .error-banner {
    display: none;
    margin-top: 0.75rem;
    padding: 0.75rem 1rem;
    background: color-mix(in srgb, #f87171 15%, var(--bg-secondary));
    border: 1px solid color-mix(in srgb, #f87171 30%, var(--border-color));
    border-radius: var(--radius-md);
    color: #fca5a5;
    font-size: 0.9rem;
  }

  .options-row {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
  }

  .options-label {
    color: var(--text-muted);
    font-size: 0.875rem;
    font-weight: 500;
  }

  .pills {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .pill {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    background: transparent;
    border: 1px solid var(--border-color);
    color: var(--text-secondary);
    padding: 0.5rem 1rem;
    border-radius: 50px;
    font-size: 0.875rem;
    transition: all var(--transition);
  }

  .pill:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  .pill.active {
    background: var(--accent);
    border-color: var(--accent);
    color: white;
  }

  .pill-count {
    background: color-mix(in srgb, var(--text-primary) 20%, transparent);
    padding: 0.125rem 0.5rem;
    border-radius: 50px;
    font-size: 0.75rem;
    font-weight: 600;
  }

  .pill.active .pill-count {
    background: color-mix(in srgb, white 20%, transparent);
  }

  .table-section {
    margin-bottom: 2rem;
  }

  .table-wrapper {
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    overflow: hidden;
    overflow-x: auto;
  }

  .alias-table {
    width: 100%;
    border-collapse: collapse;
    min-width: 800px;
  }

  .alias-table th {
    background: var(--bg-tertiary);
    color: var(--text-muted);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 1rem 1.25rem;
    text-align: left;
    border-bottom: 1px solid var(--border-color);
  }

  .alias-table td {
    padding: 1rem 1.25rem;
    border-bottom: 1px solid var(--border-color);
    vertical-align: middle;
  }

  .alias-row {
    transition: background var(--transition);
  }

  .alias-row:hover {
    background: var(--bg-tertiary);
  }

  .alias-row:last-child td {
    border-bottom: none;
  }

  .alias-address {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .alias-address code {
    color: var(--text-primary);
    font-weight: 500;
  }

  .copy-btn {
    background: transparent;
    border: none;
    color: var(--text-muted);
    padding: 0.25rem;
    border-radius: var(--radius-sm);
    cursor: pointer;
    transition: all var(--transition);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .copy-btn:hover {
    color: var(--accent);
    background: color-mix(in srgb, var(--accent) 10%, transparent);
  }

  .copy-btn.copied {
    color: #4ade80;
  }

  .alias-date {
    color: var(--text-muted);
    font-size: 0.9rem;
  }

  .alias-count {
    font-weight: 600;
    color: var(--text-secondary);
  }

  .alias-expires {
    color: var(--text-muted);
    font-size: 0.9rem;
  }

  .badge {
    display: inline-flex;
    align-items: center;
    padding: 0.25rem 0.75rem;
    border-radius: 50px;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .badge-active {
    background: color-mix(in srgb, #22c55e 15%, transparent);
    color: #4ade80;
    border: 1px solid color-mix(in srgb, #22c55e 30%, transparent);
  }

  .badge-blocked {
    background: color-mix(in srgb, #ef4444 15%, transparent);
    color: #f87171;
    border: 1px solid color-mix(in srgb, #ef4444 30%, transparent);
  }

  .alias-actions {
    display: flex;
    gap: 0.5rem;
  }

  .btn-sm {
    background: transparent;
    border: 1px solid var(--border-color);
    color: var(--text-secondary);
    padding: 0.4rem 0.75rem;
    border-radius: var(--radius-sm);
    font-size: 0.8rem;
    font-weight: 500;
    transition: all var(--transition);
    white-space: nowrap;
  }

  .btn-sm:hover:not(:disabled) {
    border-color: var(--accent);
    color: var(--accent);
  }

  .btn-sm:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .btn-toggle:hover:not(:disabled) {
    background: color-mix(in srgb, var(--accent) 10%, transparent);
  }

  .btn-danger:hover:not(:disabled) {
    border-color: #ef4444;
    color: #f87171;
    background: color-mix(in srgb, #ef4444 10%, transparent);
  }

  .empty-state {
    text-align: center;
    padding: 3rem 1rem;
    color: var(--text-muted);
    font-size: 1rem;
  }

  .load-more-section {
    text-align: center;
    padding: 1.5rem;
  }

  .load-more-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: var(--bg-tertiary);
    border: 1px solid var(--border-color);
    color: var(--text-secondary);
    padding: 0.75rem 1.5rem;
    border-radius: var(--radius-md);
    font-size: 0.9rem;
    font-weight: 500;
    transition: all var(--transition);
  }

  .load-more-btn:hover:not(:disabled) {
    border-color: var(--accent);
    color: var(--accent);
  }

  .load-more-btn:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  .toast-container {
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    z-index: 1000;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .toast {
    background: color-mix(in srgb, #f87171 15%, var(--bg-secondary));
    border: 1px solid color-mix(in srgb, #f87171 30%, var(--border-color));
    border-radius: var(--radius-md);
    padding: 0.75rem 1rem;
    color: #fca5a5;
    font-size: 0.9rem;
    animation: slideIn 0.3s ease;
    max-width: 300px;
  }

  @keyframes slideIn {
    from {
      transform: translateX(100%);
      opacity: 0;
    }
    to {
      transform: translateX(0);
      opacity: 1;
    }
  }

  @media (max-width: 768px) {
    .hero-title {
      font-size: 2rem;
    }

    .hero-subtitle {
      font-size: 0.95rem;
    }

    .stat-number {
      font-size: 2rem;
    }

    .search-bar {
      flex-wrap: wrap;
    }

    .search-btn {
      width: 100%;
      justify-content: center;
    }

    .expires-input {
      width: 100%;
    }

    .actions-row {
      flex-direction: column;
    }

    .export-section {
      width: 100%;
      justify-content: flex-end;
    }

    .toast-container {
      left: 1rem;
      right: 1rem;
      bottom: 1rem;
    }
  }
</style>

<script define:vars={{ domain: DOMAIN, mode: MODE }}>
  const formatDate = (ms) => {
    const date = new Date(ms);
    const now = new Date();
    const diff = now.getTime() - date.getTime();
    const seconds = Math.floor(diff / 1000);
    const minutes = Math.floor(seconds / 60);
    const hours = Math.floor(minutes / 60);
    const days = Math.floor(hours / 24);
    
    if (days > 30) {
      return date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
    } else if (days > 0) {
      return `${days}d ago`;
    } else if (hours > 0) {
      return `${hours}h ago`;
    } else if (minutes > 0) {
      return `${minutes}m ago`;
    } else {
      return 'Just now';
    }
  };

  function showToast(message, duration = 4000) {
    const container = document.getElementById('toast-container');
    const toast = document.createElement('div');
    toast.className = 'toast';
    toast.textContent = message;
    container.appendChild(toast);
    setTimeout(() => {
      toast.style.animation = 'slideIn 0.3s ease reverse';
      setTimeout(() => toast.remove(), 300);
    }, duration);
  }

  function showError(message) {
    showToast(message);
  }

  async function apiFetch(path, method = 'GET', body = null) {
    const opts = {
      method,
      headers: {
        'Content-Type': 'application/json',
      },
      credentials: 'same-origin'
    };
    if (body) opts.body = JSON.stringify(body);
    const res = await fetch(path, opts);
    return res;
  }

  document.querySelectorAll('.pill[data-filter]').forEach(pill => {
    pill.addEventListener('click', () => {
      document.querySelectorAll('.pill[data-filter]').forEach(p => p.classList.remove('active'));
      pill.classList.add('active');
      const filter = pill.dataset.filter;
      document.querySelectorAll('.alias-row').forEach(row => {
        if (filter === 'all' || row.dataset.status === filter) {
          row.style.display = '';
        } else {
          row.style.display = 'none';
        }
      });
    });
  });

  function attachToggleListeners() {
    document.querySelectorAll('.btn-toggle').forEach(btn => {
      btn.removeEventListener('click', handleToggle);
      btn.addEventListener('click', handleToggle);
    });
  }

  async function handleToggle(e) {
    const btn = e.currentTarget;
    const address = btn.dataset.address;
    const currentStatus = btn.dataset.status;
    const newStatus = currentStatus === 'active' ? 'blocked' : 'active';

    btn.disabled = true;
    btn.textContent = '...';

    const res = await apiFetch(
      `/api/aliases/${encodeURIComponent(address)}`,
      'PATCH',
      { status: newStatus }
    );

    if (res.ok) {
      const row = document.querySelector(`tr[data-address="${address}"]`);
      row.dataset.status = newStatus;
      btn.dataset.status = newStatus;
      btn.textContent = newStatus === 'active' ? 'Disable' : 'Enable';
      const badge = row.querySelector('.badge');
      badge.className = `badge ${newStatus === 'active' ? 'badge-active' : 'badge-blocked'}`;
      badge.textContent = newStatus;
    } else {
      btn.textContent = currentStatus === 'active' ? 'Disable' : 'Enable';
      showError('Failed to update alias.');
    }
    btn.disabled = false;
  }

  function attachDeleteListeners() {
    document.querySelectorAll('.btn-delete').forEach(btn => {
      btn.removeEventListener('click', handleDelete);
      btn.addEventListener('click', handleDelete);
    });
  }

  async function handleDelete(e) {
    const btn = e.currentTarget;
    const address = btn.dataset.address;
    if (!confirm(`Delete ${address}? This cannot be undone.`)) return;

    btn.disabled = true;
    const res = await apiFetch(
      `/api/aliases/${encodeURIComponent(address)}`,
      'DELETE'
    );

    if (res.ok) {
      document.querySelector(`tr[data-address="${address}"]`)?.remove();
    } else {
      showError('Failed to delete alias.');
      btn.disabled = false;
    }
  }

  function attachCopyListeners() {
    document.querySelectorAll('.copy-btn').forEach(btn => {
      btn.removeEventListener('click', handleCopy);
      btn.addEventListener('click', handleCopy);
    });
  }

  async function handleCopy(e) {
    const btn = e.currentTarget;
    const address = btn.dataset.address;
    
    try {
      await navigator.clipboard.writeText(address);
      btn.classList.add('copied');
      const svg = btn.querySelector('svg');
      svg.innerHTML = '<path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>';
      setTimeout(() => {
        btn.classList.remove('copied');
        svg.innerHTML = '<rect x="9" y="9" width="13" height="13" rx="2" stroke="currentColor" stroke-width="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1" stroke="currentColor" stroke-width="2"/>';
      }, 2000);
    } catch {
      showError('Failed to copy to clipboard.');
    }
  }

  let currentPage = 1;
  const limit = 100;

  async function loadMore() {
    const btn = document.getElementById('load-more-btn');
    const spinner = document.getElementById('load-more-spinner');
    const label = document.getElementById('load-more-label');
    
    btn.disabled = true;
    spinner.style.display = 'block';
    label.textContent = 'Loading…';
    
    currentPage++;
    const res = await apiFetch(`/api/aliases?page=${currentPage}&limit=${limit}`);
    const data = await res.json();
    
    if (res.ok && data.aliases?.length > 0) {
      const tbody = document.getElementById('alias-tbody');
      
      data.aliases.forEach(alias => {
        const row = document.createElement('tr');
        row.dataset.address = alias.address;
        row.dataset.status = alias.status;
        row.className = 'alias-row';
        row.innerHTML = `
          <td class="alias-address">
            <code>${alias.address}</code>
            <button class="copy-btn" data-address="${alias.address}" title="Copy to clipboard">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <rect x="9" y="9" width="13" height="13" rx="2" stroke="currentColor" stroke-width="2"/>
                <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1" stroke="currentColor" stroke-width="2"/>
              </svg>
            </button>
          </td>
          <td class="alias-date">${formatDate(alias.first_seen)}</td>
          <td class="alias-date">${formatDate(alias.last_seen)}</td>
          <td class="alias-count">${alias.mail_count}</td>
          <td class="alias-expires">${alias.expires_at ? formatDate(alias.expires_at) : '-'}</td>
          <td>
            <span class="badge ${alias.status === 'active' ? 'badge-active' : 'badge-blocked'}">
              ${alias.status}
            </span>
          </td>
          <td class="alias-actions">
            <button class="btn-sm btn-toggle" data-address="${alias.address}" data-status="${alias.status}">
              ${alias.status === 'active' ? 'Disable' : 'Enable'}
            </button>
            <button class="btn-sm btn-delete btn-danger" data-address="${alias.address}">
              Delete
            </button>
          </td>
        `;
        tbody.appendChild(row);
      });
      
      attachToggleListeners();
      attachDeleteListeners();
      attachCopyListeners();
      
      if (data.aliases.length < limit) {
        btn.remove();
      } else {
        btn.disabled = false;
        spinner.style.display = 'none';
        label.textContent = 'Load More';
      }
    } else {
      btn.remove();
    }
  }

  document.getElementById('load-more-btn')?.addEventListener('click', loadMore);

  attachToggleListeners();
  attachDeleteListeners();
  attachCopyListeners();

  if (mode === 'specific') {
    const input = document.getElementById('new-alias-input');
    const expiresInput = document.getElementById('expires-input');
    const btn = document.getElementById('add-alias-btn');
    const errorEl = document.getElementById('add-error');
    const spinner = document.getElementById('add-spinner');
    const label = document.getElementById('add-label');

    btn?.addEventListener('click', async () => {
      const address = input.value.trim().toLowerCase();
      const expiresAt = expiresInput.value ? new Date(expiresInput.value).getTime() : null;
      errorEl.style.display = 'none';

      if (!address) return;
      if (!address.endsWith(`@${domain}`)) {
        errorEl.textContent = `Address must end with @${domain}`;
        errorEl.style.display = 'block';
        return;
      }

      btn.disabled = true;
      spinner.style.display = 'block';
      label.textContent = 'Adding…';

      const body = { address };
      if (expiresAt) body.expires_at = expiresAt;
      
      const res = await apiFetch('/api/aliases', 'POST', body);
      const data = await res.json();

      if (res.ok) {
        input.value = '';
        expiresInput.value = '';
        const tbody = document.getElementById('alias-tbody');
        const now = Date.now();
        tbody.insertAdjacentHTML('afterbegin', `
          <tr data-address="${address}" data-status="active" class="alias-row">
            <td class="alias-address">
              <code>${address}</code>
              <button class="copy-btn" data-address="${address}" title="Copy to clipboard">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <rect x="9" y="9" width="13" height="13" rx="2" stroke="currentColor" stroke-width="2"/>
                  <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1" stroke="currentColor" stroke-width="2"/>
                </svg>
              </button>
            </td>
            <td class="alias-date">${formatDate(now)}</td>
            <td class="alias-date">${formatDate(now)}</td>
            <td class="alias-count">0</td>
            <td class="alias-expires">${expiresAt ? formatDate(expiresAt) : '-'}</td>
            <td><span class="badge badge-active">active</span></td>
            <td class="alias-actions">
              <button class="btn-sm btn-toggle" data-address="${address}" data-status="active">Disable</button>
              <button class="btn-sm btn-delete btn-danger" data-address="${address}">Delete</button>
            </td>
          </tr>
        `);
        attachToggleListeners();
        attachDeleteListeners();
        attachCopyListeners();
      } else {
        errorEl.textContent = data.error ?? 'Failed to add alias.';
        errorEl.style.display = 'block';
      }

      btn.disabled = false;
      spinner.style.display = 'none';
      label.textContent = 'Add Alias';
    });

    input?.addEventListener('keypress', (e) => {
      if (e.key === 'Enter') {
        btn.click();
      }
    });
  }
</script>
