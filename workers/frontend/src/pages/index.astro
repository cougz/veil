---
import Layout from '../layouts/Layout.astro';
import { verifyAccessToken } from '../lib/auth';
import { formatDate } from '../lib/dates';

const env = Astro.locals.runtime.env;
const APP_NAME: string        = env.APP_NAME        ?? 'Veil';
const APP_DESCRIPTION: string = env.APP_DESCRIPTION ?? 'Wildcard email aliasing. Forward, filter, and burn addresses without exposing your inbox.';
const ACCENT_COLOR: string    = env.ACCENT_COLOR    ?? '#6d83f2';
const DOMAIN: string          = env.DOMAIN          ?? 'yourdomain.com';

let userEmail = 'unknown';
try {
  const payload = await verifyAccessToken(Astro.request, env);
  userEmail = payload.email;
} catch {
  return new Response('Unauthorized', { status: 401 });
}

const db = env.DB;
const { results: aliases } = await db
  .prepare('SELECT * FROM aliases ORDER BY last_seen DESC LIMIT 500')
  .all();

const total   = aliases.length;
const active  = aliases.filter((a: any) => a.status === 'active').length;
const blocked = aliases.filter((a: any) => a.status === 'blocked').length;

const now = Math.floor(Date.now() / 1000);
const ts7d  = now - 7 * 86400;
const ts30d = now - 30 * 86400;
const ts6mo = now - 180 * 86400;
const ts12mo = now - 365 * 86400;

const emailRow = await db.prepare(`
  SELECT
    COUNT(*) as total_all,
    SUM(CASE WHEN event = 'forwarded' THEN 1 ELSE 0 END) as forwarded_all,
    SUM(CASE WHEN event = 'blocked' THEN 1 ELSE 0 END) as blocked_all,
    SUM(CASE WHEN timestamp >= ?1 THEN 1 ELSE 0 END) as total_7d,
    SUM(CASE WHEN timestamp >= ?1 AND event = 'forwarded' THEN 1 ELSE 0 END) as forwarded_7d,
    SUM(CASE WHEN timestamp >= ?1 AND event = 'blocked' THEN 1 ELSE 0 END) as blocked_7d,
    SUM(CASE WHEN timestamp >= ?2 THEN 1 ELSE 0 END) as total_30d,
    SUM(CASE WHEN timestamp >= ?2 AND event = 'forwarded' THEN 1 ELSE 0 END) as forwarded_30d,
    SUM(CASE WHEN timestamp >= ?2 AND event = 'blocked' THEN 1 ELSE 0 END) as blocked_30d,
    SUM(CASE WHEN timestamp >= ?3 THEN 1 ELSE 0 END) as total_6mo,
    SUM(CASE WHEN timestamp >= ?3 AND event = 'forwarded' THEN 1 ELSE 0 END) as forwarded_6mo,
    SUM(CASE WHEN timestamp >= ?3 AND event = 'blocked' THEN 1 ELSE 0 END) as blocked_6mo,
    SUM(CASE WHEN timestamp >= ?4 THEN 1 ELSE 0 END) as total_12mo,
    SUM(CASE WHEN timestamp >= ?4 AND event = 'forwarded' THEN 1 ELSE 0 END) as forwarded_12mo,
    SUM(CASE WHEN timestamp >= ?4 AND event = 'blocked' THEN 1 ELSE 0 END) as blocked_12mo
  FROM logs
`).bind(ts7d, ts30d, ts6mo, ts12mo).first();

const e = emailRow as any;
const emailStats = JSON.stringify({
  '7d':   { total: e?.total_7d   ?? 0, forwarded: e?.forwarded_7d   ?? 0, blocked: e?.blocked_7d   ?? 0 },
  '30d':  { total: e?.total_30d  ?? 0, forwarded: e?.forwarded_30d  ?? 0, blocked: e?.blocked_30d  ?? 0 },
  '6mo':  { total: e?.total_6mo  ?? 0, forwarded: e?.forwarded_6mo  ?? 0, blocked: e?.blocked_6mo  ?? 0 },
  '12mo': { total: e?.total_12mo ?? 0, forwarded: e?.forwarded_12mo ?? 0, blocked: e?.blocked_12mo ?? 0 },
  'all':  { total: e?.total_all  ?? 0, forwarded: e?.forwarded_all  ?? 0, blocked: e?.blocked_all  ?? 0 },
});
---

<Layout title={APP_NAME} accentColor={ACCENT_COLOR}>
<div class="page-header">
    <div class="user-menu">
      <button class="user-menu-trigger" id="user-menu-trigger">
        <span class="user-avatar">{userEmail.charAt(0).toUpperCase()}</span>
        <span class="user-name">{userEmail}</span>
        <svg class="chevron" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="6 9 12 15 18 9"/>
        </svg>
      </button>
      <div class="user-menu-dropdown" id="user-menu-dropdown">
        <a href="/logs" class="dropdown-item">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
            <polyline points="14 2 14 8 20 8"/>
            <line x1="16" y1="13" x2="8" y2="13"/>
            <line x1="16" y1="17" x2="8" y2="17"/>
            <polyline points="10 9 9 9 8 9"/>
          </svg>
          Logs
        </a>
        <a href="/settings" class="dropdown-item">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="3"/>
            <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/>
          </svg>
          Settings
        </a>
        <div class="dropdown-divider"></div>
        <a href={`${env.CF_ACCESS_TEAM_DOMAIN}/cdn-cgi/access/logout`} class="dropdown-item dropdown-item-danger">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
            <polyline points="16 17 21 12 16 7"/>
            <line x1="21" y1="12" x2="9" y2="12"/>
          </svg>
          Logout
        </a>
      </div>
    </div>
  </div>

  <section class="hero">
    <h1 class="hero-title">Welcome to {APP_NAME}</h1>
    <p class="hero-subtitle">
      {APP_DESCRIPTION}
      <br>
      <span class="powered-by">
        Powered by
        <svg viewBox="0 0 50 50" width="18" height="18" fill="currentColor" aria-hidden="true" class="cf-workers-icon">
          <path d="m18.63 37.418-9.645-12.9 9.592-12.533-1.852-2.527L5.917 23.595l-.015 1.808 10.86 14.542z"></path>
          <path d="M21.997 6.503h-3.712l13.387 18.3-13.072 17.7h3.735L35.4 24.81z"></path>
          <path d="M29.175 6.503h-3.758l13.598 18.082-13.598 17.918h3.765l12.908-17.01v-1.808z"></path>
        </svg>
        <a href="https://developers.cloudflare.com/workers/" target="_blank" rel="noopener">Cloudflare Workers</a>
      </span>
    </p>
  </section>

  <div class="stats-row">
    <div class="stat-card">
      <span class="stat-number">{total}</span>
      <span class="stat-label">Total Aliases</span>
    </div>
    <div class="stat-card">
      <span class="stat-number">{active}</span>
      <span class="stat-label">Enabled</span>
    </div>
    <div class="stat-card">
      <span class="stat-number">{blocked}</span>
      <span class="stat-label">Disabled</span>
    </div>
  </div>

  <div class="email-stats-header">
    <span class="options-label">Email Activity</span>
    <div class="seg-group" id="range-group">
      <div class="seg-indicator"></div>
      <button class="seg" data-range="7d">7d</button>
      <button class="seg" data-range="30d">30d</button>
      <button class="seg active" data-range="6mo">6mo</button>
      <button class="seg" data-range="12mo">12mo</button>
      <button class="seg" data-range="all">All</button>
    </div>
  </div>
  <div class="stats-row">
    <div class="stat-card">
      <span class="stat-number" id="stat-forwarded">{e?.forwarded_6mo ?? 0}</span>
      <span class="stat-label">Forwarded</span>
    </div>
    <div class="stat-card">
      <span class="stat-number" id="stat-blocked">{e?.blocked_6mo ?? 0}</span>
      <span class="stat-label">Blocked</span>
    </div>
    <div class="stat-card">
      <span class="stat-number" id="stat-total">{e?.total_6mo ?? 0}</span>
      <span class="stat-label">Total Processed</span>
    </div>
  </div>

  <div class="options-row">
    <span class="options-label">Filter:</span>
    <div class="seg-group" id="filter-group">
      <div class="seg-indicator"></div>
      <button class="seg active" data-filter="all">All <span class="seg-count">{total}</span></button>
      <button class="seg" data-filter="active">Enabled <span class="seg-count">{active}</span></button>
      <button class="seg" data-filter="blocked">Disabled <span class="seg-count">{blocked}</span></button>
    </div>
    <input type="text" class="search-input" id="alias-search" placeholder="Search aliases..." />
    <a href="/api/aliases/export" class="btn-export" download="aliases.csv">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
        <polyline points="7 10 12 15 17 10"/>
        <line x1="12" y1="15" x2="12" y2="3"/>
      </svg>
      Export CSV
    </a>
  </div>

  <section class="table-section">
    <div class="table-wrapper">
      <table class="alias-table" id="alias-table">
        <thead>
          <tr>
            <th class="sortable" data-sort="address">Address <span class="sort-indicator"></span></th>
            <th class="sortable" data-sort="first_seen">First Seen <span class="sort-indicator"></span></th>
            <th class="sortable" data-sort="last_seen">Last Seen <span class="sort-indicator"></span></th>
            <th class="sortable" data-sort="mail_count">Mails <span class="sort-indicator"></span></th>
            <th class="sortable" data-sort="status">Status <span class="sort-indicator"></span></th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody id="alias-tbody">
          {aliases.map((alias: any) => (
            <tr data-address={alias.address} data-status={alias.status} data-first-seen={alias.first_seen} data-last-seen={alias.last_seen} data-mail-count={alias.mail_count} class="alias-row">
              <td class="alias-address">
                <code>{alias.address}</code>
              </td>
              <td class="alias-date">{formatDate(alias.first_seen)}</td>
              <td class="alias-date">{formatDate(alias.last_seen)}</td>
              <td class="alias-count">{alias.mail_count}</td>
              <td>
                <span class={`badge ${alias.status === 'active' ? 'badge-active' : 'badge-blocked'}`}>
                  {alias.status === 'active' ? 'Enabled' : 'Disabled'}
                </span>
              </td>
              <td class="alias-actions">
                <button class="btn-sm btn-toggle" data-address={alias.address} data-status={alias.status}>
                  {alias.status === 'active' ? 'Disable' : 'Enable'}
                </button>
                <button class="btn-sm btn-delete btn-danger" data-address={alias.address}>
                  Delete
                </button>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
      {aliases.length === 0 && (
        <div class="empty-state">
          No aliases yet. Send an email to any address to get started.
        </div>
      )}
    </div>
  </section>
</Layout>

<style>
  .page-header {
    display: flex;
    justify-content: flex-end;
    margin-bottom: 1rem;
  }

  .user-menu {
    position: relative;
  }

  .user-menu-trigger {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.35rem 0.75rem 0.35rem 0.35rem;
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: 50px;
    cursor: pointer;
    transition: all var(--transition);
  }

  .user-menu-trigger:hover {
    border-color: var(--accent);
  }

  .user-menu.open .user-menu-trigger {
    border-color: var(--accent);
    background: var(--bg-tertiary);
  }

  .user-menu.open .chevron {
    transform: rotate(180deg);
  }

  .user-avatar {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: color-mix(in srgb, var(--accent) 80%, transparent);
    color: white;
    font-size: 0.8rem;
    font-weight: 600;
  }

  .user-name {
    color: var(--text-secondary);
    font-size: 0.8rem;
    max-width: 180px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .chevron {
    color: var(--text-muted);
    transition: transform var(--transition);
  }

  .user-menu-dropdown {
    position: fixed;
    width: 220px;
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
    padding: 0.25rem;
    opacity: 0;
    visibility: hidden;
    transform: translateY(-4px);
    transition: all var(--transition);
    z-index: 1000;
  }

  .user-menu.open .user-menu-dropdown {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .user-menu-header {
    padding: 0.75rem 0.75rem 0.5rem;
    border-bottom: 1px solid var(--border-color);
    margin-bottom: 0.25rem;
  }

  .dropdown-email {
    color: var(--text-muted);
    font-size: 0.75rem;
    word-break: break-all;
  }

  .dropdown-item {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.6rem 0.75rem;
    color: var(--text-secondary);
    text-decoration: none;
    font-size: 0.875rem;
    font-weight: 500;
    border-radius: var(--radius-sm);
    transition: all var(--transition);
  }

  .dropdown-item:hover {
    background: color-mix(in srgb, var(--accent) 10%, transparent);
    color: var(--accent);
  }

  .dropdown-item svg {
    flex-shrink: 0;
    opacity: 0.6;
  }

  .dropdown-item:hover svg {
    opacity: 1;
  }

  .dropdown-item-danger:hover {
    background: color-mix(in srgb, #ef4444 10%, transparent);
    color: #f87171;
  }

  .dropdown-divider {
    height: 1px;
    background: var(--border-color);
    margin: 0.25rem 0.5rem;
  }

  .hero {
    text-align: center;
    padding: 80px 0 40px;
    max-width: 680px;
    width: 100%;
    margin: 0 auto;
  }

  .hero-title {
    font-size: 2.8rem;
    font-weight: 700;
    line-height: 1.15;
    margin-bottom: 16px;
    background: linear-gradient(135deg, #ffffff 0%, var(--accent) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-subtitle {
    font-size: 1rem;
    color: var(--text-secondary);
    line-height: 1.6;
    max-width: 480px;
    margin: 0 auto;
  }

  .powered-by {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: 0.85em;
    color: var(--text-muted);
    margin-top: 8px;
  }

  .powered-by svg {
    color: var(--accent);
    vertical-align: text-bottom;
  }

  .powered-by a {
    color: var(--accent);
    font-weight: 500;
    text-decoration: none;
    transition: color var(--transition);
  }

  .powered-by a:hover {
    color: var(--accent-light);
  }

  .stats-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .email-stats-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 0.75rem;
    flex-wrap: wrap;
  }

  .stats-row:last-of-type {
    margin-bottom: 2rem;
  }

  @media (max-width: 600px) {
    .stats-row {
      grid-template-columns: 1fr;
    }
  }

  .stat-card {
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    text-align: center;
    transition: all var(--transition);
  }

  .stat-card:hover {
    border-color: var(--accent);
    box-shadow: var(--shadow-accent);
  }

  .stat-number {
    display: block;
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 0.25rem;
  }

  .stat-label {
    color: var(--text-muted);
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .options-row {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
  }

  .search-input {
    margin-left: auto;
    padding: 0.5rem 1rem;
    border: 1px solid var(--border-color);
    border-radius: var(--radius-sm);
    background: var(--bg-secondary);
    color: var(--text-primary);
    font-size: 0.875rem;
    min-width: 200px;
    transition: all var(--transition);
  }

  .search-input:focus {
    outline: none;
    border-color: var(--accent);
    box-shadow: 0 0 0 2px color-mix(in srgb, var(--accent) 20%, transparent);
  }

  .search-input::placeholder {
    color: var(--text-muted);
  }

  .btn-export {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.5rem 1rem;
    background: transparent;
    border: 1px solid var(--border-color);
    color: var(--text-muted);
    border-radius: var(--radius-sm);
    font-size: 0.8rem;
    font-weight: 500;
    text-decoration: none;
    transition: all var(--transition);
    white-space: nowrap;
  }

  .btn-export:hover {
    border-color: var(--accent);
    color: var(--accent);
    background: color-mix(in srgb, var(--accent) 10%, transparent);
  }

  .options-label {
    color: var(--text-muted);
    font-size: 0.875rem;
    font-weight: 500;
  }

  .seg-group {
    display: inline-flex;
    background: color-mix(in srgb, var(--text-primary) 5%, transparent);
    border-radius: 0.5rem;
    padding: 2px;
    position: relative;
  }

  .seg {
    position: relative;
    z-index: 1;
    background: none;
    border: none;
    color: var(--text-secondary);
    padding: 2px 10px;
    border-radius: calc(0.5rem - 2px);
    font-size: 0.75rem;
    font-weight: 500;
    line-height: 1.5;
    cursor: pointer;
    transition: color 200ms ease;
    white-space: nowrap;
  }

  .seg:hover {
    color: var(--text-primary);
  }

  .seg.active {
    color: var(--text-primary);
  }

  .seg-count {
    font-size: 0.6rem;
    opacity: 0.5;
    margin-left: 1px;
    font-weight: 600;
    vertical-align: super;
  }

  .seg-indicator {
    position: absolute;
    top: 2px;
    height: calc(100% - 4px);
    background: color-mix(in srgb, var(--text-primary) 10%, transparent);
    border-radius: calc(0.5rem - 2px);
    transition: all 200ms ease;
    z-index: 0;
    pointer-events: none;
  }

  .table-section {
    margin-bottom: 2rem;
  }

  .table-wrapper {
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    overflow: hidden;
    overflow-x: auto;
  }

  .alias-table {
    width: 100%;
    border-collapse: collapse;
    min-width: 700px;
  }

  .alias-table th {
    background: var(--bg-tertiary);
    color: var(--text-muted);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 1rem 1.25rem;
    text-align: left;
    border-bottom: 1px solid var(--border-color);
  }

  .alias-table th.sortable {
    cursor: pointer;
    user-select: none;
    transition: color var(--transition);
  }

  .alias-table th.sortable:hover {
    color: var(--text-primary);
  }

  .sort-indicator {
    display: inline-block;
    margin-left: 0.25rem;
    opacity: 0.5;
  }

  .sort-indicator::after {
    content: '↕';
  }

  th.sort-asc .sort-indicator::after {
    content: '↑';
    opacity: 1;
  }

  th.sort-desc .sort-indicator::after {
    content: '↓';
    opacity: 1;
  }

  .alias-table td {
    padding: 1rem 1.25rem;
    border-bottom: 1px solid var(--border-color);
    vertical-align: middle;
  }

  .alias-row {
    transition: background var(--transition);
  }

  .alias-row:hover {
    background: var(--bg-tertiary);
  }

  .alias-row:last-child td {
    border-bottom: none;
  }

  .alias-address code {
    color: var(--text-primary);
    font-weight: 500;
  }

  .alias-date {
    color: var(--text-muted);
    font-size: 0.9rem;
  }

  .alias-count {
    font-weight: 600;
    color: var(--text-secondary);
  }

  .badge {
    display: inline-flex;
    align-items: center;
    padding: 0.25rem 0.75rem;
    border-radius: 50px;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .badge-active {
    background: color-mix(in srgb, #22c55e 15%, transparent);
    color: #4ade80;
    border: 1px solid color-mix(in srgb, #22c55e 30%, transparent);
  }

  .badge-blocked {
    background: color-mix(in srgb, #ef4444 15%, transparent);
    color: #f87171;
    border: 1px solid color-mix(in srgb, #ef4444 30%, transparent);
  }

  .alias-actions {
    display: flex;
    gap: 0.5rem;
  }

  .btn-sm {
    background: transparent;
    border: 1px solid var(--border-color);
    color: var(--text-secondary);
    padding: 0.4rem 0.75rem;
    border-radius: var(--radius-sm);
    font-size: 0.8rem;
    font-weight: 500;
    transition: all var(--transition);
    white-space: nowrap;
  }

  .btn-sm:hover:not(:disabled) {
    border-color: var(--accent);
    color: var(--accent);
  }

  .btn-sm:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .btn-toggle:hover:not(:disabled) {
    background: color-mix(in srgb, var(--accent) 10%, transparent);
  }

  .btn-danger:hover:not(:disabled) {
    border-color: #ef4444;
    color: #f87171;
    background: color-mix(in srgb, #ef4444 10%, transparent);
  }

  .empty-state {
    text-align: center;
    padding: 3rem 1rem;
    color: var(--text-muted);
    font-size: 1rem;
  }

  @media (max-width: 768px) {
    .hero {
      padding: 56px 0 32px;
    }

    .hero-title {
      font-size: 2rem;
