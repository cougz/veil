---
import Layout from '../layouts/Layout.astro';
import { verifyAccessToken } from '../lib/auth';
import { formatDate } from '../lib/dates';

const env = Astro.locals.runtime.env;
const APP_NAME: string        = env.APP_NAME        ?? 'Veil';
const APP_DESCRIPTION: string = env.APP_DESCRIPTION ?? 'Wildcard email aliasing. Forward, filter, and burn addresses without exposing your inbox.';
const ACCENT_COLOR: string    = env.ACCENT_COLOR    ?? '#6d83f2';
const DOMAIN: string          = env.DOMAIN          ?? 'yourdomain.com';

let userEmail = 'unknown';
try {
  const payload = await verifyAccessToken(Astro.request, env);
  userEmail = payload.email;
} catch {
  return new Response('Unauthorized', { status: 401 });
}

const db = env.DB;
const { results: aliases } = await db
  .prepare('SELECT * FROM aliases ORDER BY last_seen DESC LIMIT 500')
  .all();

const total   = aliases.length;
const active  = aliases.filter((a: any) => a.status === 'active').length;
const blocked = aliases.filter((a: any) => a.status === 'blocked').length;
---

<Layout title={APP_NAME} accentColor={ACCENT_COLOR}>
<div class="page-header">
    <span class="user-badge">{userEmail}</span>
    <a href="/logs" class="header-link">Logs</a>
    <a href={`${env.CF_ACCESS_TEAM_DOMAIN}/cdn-cgi/access/logout`} class="btn-logout">
      <span class="logout-icon">
        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
          <polyline points="16 17 21 12 16 7"/>
          <line x1="21" y1="12" x2="9" y2="12"/>
        </svg>
      </span>
      <span class="logout-text">Logout</span>
    </a>
    <a href="/settings" class="btn-settings">
      <svg class="settings-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="3"/>
        <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/>
      </svg>
      Settings
    </a>
  </div>

  <section class="hero">
    <h1 class="hero-title">Welcome to {APP_NAME}</h1>
    <p class="hero-subtitle">
      {APP_DESCRIPTION}
      <br>
      <span class="powered-by">
        Powered by
        <svg viewBox="0 0 50 50" width="18" height="18" fill="currentColor" aria-hidden="true" class="cf-workers-icon">
          <path d="m18.63 37.418-9.645-12.9 9.592-12.533-1.852-2.527L5.917 23.595l-.015 1.808 10.86 14.542z"></path>
          <path d="M21.997 6.503h-3.712l13.387 18.3-13.072 17.7h3.735L35.4 24.81z"></path>
          <path d="M29.175 6.503h-3.758l13.598 18.082-13.598 17.918h3.765l12.908-17.01v-1.808z"></path>
        </svg>
        <a href="https://developers.cloudflare.com/workers/" target="_blank" rel="noopener">Cloudflare Workers</a>
      </span>
    </p>
  </section>

  <div class="stats-row">
    <div class="stat-card">
      <span class="stat-number">{total}</span>
      <span class="stat-label">Total Aliases</span>
    </div>
    <div class="stat-card">
      <span class="stat-number">{active}</span>
      <span class="stat-label">Active</span>
    </div>
    <div class="stat-card">
      <span class="stat-number">{blocked}</span>
      <span class="stat-label">Blocked</span>
    </div>
  </div>

  <div class="options-row">
    <span class="options-label">Filter:</span>
    <div class="pills">
      <button class="pill active" data-filter="all">All <span class="pill-count">{total}</span></button>
      <button class="pill" data-filter="active">Active <span class="pill-count">{active}</span></button>
      <button class="pill" data-filter="blocked">Blocked <span class="pill-count">{blocked}</span></button>
    </div>
    <input type="text" class="search-input" id="alias-search" placeholder="Search aliases..." />
    <a href="/api/aliases/export" class="btn-export" download="aliases.csv">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
        <polyline points="7 10 12 15 17 10"/>
        <line x1="12" y1="15" x2="12" y2="3"/>
      </svg>
      Export CSV
    </a>
  </div>

  <section class="table-section">
    <div class="table-wrapper">
      <table class="alias-table" id="alias-table">
        <thead>
          <tr>
            <th class="sortable" data-sort="address">Address <span class="sort-indicator"></span></th>
            <th class="sortable" data-sort="first_seen">First Seen <span class="sort-indicator"></span></th>
            <th class="sortable" data-sort="last_seen">Last Seen <span class="sort-indicator"></span></th>
            <th class="sortable" data-sort="mail_count">Mails <span class="sort-indicator"></span></th>
            <th class="sortable" data-sort="status">Status <span class="sort-indicator"></span></th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody id="alias-tbody">
          {aliases.map((alias: any) => (
            <tr data-address={alias.address} data-status={alias.status} data-first-seen={alias.first_seen} data-last-seen={alias.last_seen} data-mail-count={alias.mail_count} class="alias-row">
              <td class="alias-address">
                <code>{alias.address}</code>
              </td>
              <td class="alias-date">{formatDate(alias.first_seen)}</td>
              <td class="alias-date">{formatDate(alias.last_seen)}</td>
              <td class="alias-count">{alias.mail_count}</td>
              <td>
                <span class={`badge ${alias.status === 'active' ? 'badge-active' : 'badge-blocked'}`}>
                  {alias.status}
                </span>
              </td>
              <td class="alias-actions">
                <button class="btn-sm btn-toggle" data-address={alias.address} data-status={alias.status}>
                  {alias.status === 'active' ? 'Disable' : 'Enable'}
                </button>
                <button class="btn-sm btn-delete btn-danger" data-address={alias.address}>
                  Delete
                </button>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
      {aliases.length === 0 && (
        <div class="empty-state">
          No aliases yet. Send an email to any address to get started.
        </div>
      )}
    </div>
  </section>
</Layout>

<style>
  .page-header {
    display: flex;
    justify-content: flex-end;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .user-badge {
    color: var(--text-muted);
    font-size: 0.875rem;
    padding: 0.5rem 1rem;
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
  }

  .header-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--text-muted);
    text-decoration: none;
    font-size: 0.875rem;
    transition: color var(--transition);
    padding: 0.5rem 1rem;
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
  }

  .header-link:hover {
    color: var(--accent);
    border-color: var(--accent);
  }

  .btn-settings {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    height: 36px;
    padding: 6px 14px;
    background: color-mix(in srgb, var(--accent) 20%, transparent);
    border-radius: 20px;
    color: var(--accent);
    text-decoration: none;
    font-size: 0.875rem;
    font-weight: 500;
    letter-spacing: 0.5px;
    transition: background var(--transition);
  }

  .btn-settings:hover {
    background: color-mix(in srgb, var(--accent) 30%, transparent);
  }

  .btn-settings:hover .settings-icon {
    animation: settings-spin 2s linear infinite;
  }

  @keyframes settings-spin {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
  }

  .btn-logout {
    display: flex;
    align-items: center;
    width: 45px;
    height: 45px;
    border-radius: 50%;
    background: color-mix(in srgb, #ef4444 80%, transparent);
    box-shadow: 2px 2px 10px rgba(0, 0, 0, 0.2);
    overflow: hidden;
    text-decoration: none;
    transition: all .3s;
  }

  .btn-logout:hover {
    width: 125px;
    border-radius: 40px;
  }

  .logout-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    transition: all .3s;
  }

  .btn-logout:hover .logout-icon {
    width: 30%;
    padding-left: 14px;
  }

  .logout-text {
    position: absolute;
    right: 0;
    width: 0;
    opacity: 0;
    color: white;
    font-size: 1rem;
    font-weight: 600;
    transition: all .3s;
  }

  .btn-logout:hover .logout-text {
    opacity: 1;
    width: 70%;
    padding-right: 10px;
  }

  .btn-logout:active {
    transform: translate(2px, 2px);
  }

  .hero {
    text-align: center;
    padding: 80px 0 40px;
    max-width: 680px;
    width: 100%;
    margin: 0 auto;
  }

  .hero-title {
    font-size: 2.8rem;
    font-weight: 700;
    line-height: 1.15;
    margin-bottom: 16px;
    background: linear-gradient(135deg, #ffffff 0%, var(--accent) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-subtitle {
    font-size: 1rem;
    color: var(--text-secondary);
    line-height: 1.6;
    max-width: 480px;
    margin: 0 auto;
  }

  .powered-by {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: 0.85em;
    color: var(--text-muted);
    margin-top: 8px;
  }

  .powered-by svg {
    color: var(--accent);
    vertical-align: text-bottom;
  }

  .powered-by a {
    color: var(--accent);
    font-weight: 500;
    text-decoration: none;
    transition: color var(--transition);
  }

  .powered-by a:hover {
    color: var(--accent-light);
  }

  .stats-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    margin-bottom: 2rem;
  }

  @media (max-width: 600px) {
    .stats-row {
      grid-template-columns: 1fr;
    }
  }

  .stat-card {
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    text-align: center;
    transition: all var(--transition);
  }

  .stat-card:hover {
    border-color: var(--accent);
    box-shadow: var(--shadow-accent);
  }

  .stat-number {
    display: block;
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 0.25rem;
  }

  .stat-label {
    color: var(--text-muted);
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .options-row {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
  }

  .search-input {
    margin-left: auto;
    padding: 0.5rem 1rem;
    border: 1px solid var(--border-color);
    border-radius: var(--radius-sm);
    background: var(--bg-secondary);
    color: var(--text-primary);
    font-size: 0.875rem;
    min-width: 200px;
    transition: all var(--transition);
  }

  .search-input:focus {
    outline: none;
    border-color: var(--accent);
    box-shadow: 0 0 0 2px color-mix(in srgb, var(--accent) 20%, transparent);
  }

  .search-input::placeholder {
    color: var(--text-muted);
  }

  .btn-export {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.5rem 1rem;
    background: transparent;
    border: 1px solid var(--border-color);
    color: var(--text-muted);
    border-radius: var(--radius-sm);
    font-size: 0.8rem;
    font-weight: 500;
    text-decoration: none;
    transition: all var(--transition);
    white-space: nowrap;
  }

  .btn-export:hover {
    border-color: var(--accent);
    color: var(--accent);
    background: color-mix(in srgb, var(--accent) 10%, transparent);
  }

  .options-label {
    color: var(--text-muted);
    font-size: 0.875rem;
    font-weight: 500;
  }

  .pills {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .pill {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    background: transparent;
    border: 1px solid var(--border-color);
    color: var(--text-secondary);
    padding: 0.5rem 1rem;
    border-radius: 50px;
    font-size: 0.875rem;
    transition: all var(--transition);
  }

  .pill:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  .pill.active {
    background: var(--accent);
    border-color: var(--accent);
    color: white;
  }

  .pill-count {
    background: color-mix(in srgb, var(--text-primary) 20%, transparent);
    padding: 0.125rem 0.5rem;
    border-radius: 50px;
    font-size: 0.75rem;
    font-weight: 600;
  }

  .pill.active .pill-count {
    background: color-mix(in srgb, white 20%, transparent);
  }

  .table-section {
    margin-bottom: 2rem;
  }

  .table-wrapper {
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    overflow: hidden;
    overflow-x: auto;
  }

  .alias-table {
    width: 100%;
    border-collapse: collapse;
    min-width: 700px;
  }

  .alias-table th {
    background: var(--bg-tertiary);
    color: var(--text-muted);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 1rem 1.25rem;
    text-align: left;
    border-bottom: 1px solid var(--border-color);
  }

  .alias-table th.sortable {
    cursor: pointer;
    user-select: none;
    transition: color var(--transition);
  }

  .alias-table th.sortable:hover {
    color: var(--text-primary);
  }

  .sort-indicator {
    display: inline-block;
    margin-left: 0.25rem;
    opacity: 0.5;
  }

  .sort-indicator::after {
    content: '↕';
  }

  th.sort-asc .sort-indicator::after {
    content: '↑';
    opacity: 1;
  }

  th.sort-desc .sort-indicator::after {
    content: '↓';
    opacity: 1;
  }

  .alias-table td {
    padding: 1rem 1.25rem;
    border-bottom: 1px solid var(--border-color);
    vertical-align: middle;
  }

  .alias-row {
    transition: background var(--transition);
  }

  .alias-row:hover {
    background: var(--bg-tertiary);
  }

  .alias-row:last-child td {
    border-bottom: none;
  }

  .alias-address code {
    color: var(--text-primary);
    font-weight: 500;
  }

  .alias-date {
    color: var(--text-muted);
    font-size: 0.9rem;
  }

  .alias-count {
    font-weight: 600;
    color: var(--text-secondary);
  }

  .badge {
    display: inline-flex;
    align-items: center;
    padding: 0.25rem 0.75rem;
    border-radius: 50px;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .badge-active {
    background: color-mix(in srgb, #22c55e 15%, transparent);
    color: #4ade80;
    border: 1px solid color-mix(in srgb, #22c55e 30%, transparent);
  }

  .badge-blocked {
    background: color-mix(in srgb, #ef4444 15%, transparent);
    color: #f87171;
    border: 1px solid color-mix(in srgb, #ef4444 30%, transparent);
  }

  .alias-actions {
    display: flex;
    gap: 0.5rem;
  }

  .btn-sm {
    background: transparent;
    border: 1px solid var(--border-color);
    color: var(--text-secondary);
    padding: 0.4rem 0.75rem;
    border-radius: var(--radius-sm);
    font-size: 0.8rem;
    font-weight: 500;
    transition: all var(--transition);
    white-space: nowrap;
  }

  .btn-sm:hover:not(:disabled) {
    border-color: var(--accent);
    color: var(--accent);
  }

  .btn-sm:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .btn-toggle:hover:not(:disabled) {
    background: color-mix(in srgb, var(--accent) 10%, transparent);
  }

  .btn-danger:hover:not(:disabled) {
    border-color: #ef4444;
    color: #f87171;
    background: color-mix(in srgb, #ef4444 10%, transparent);
  }

  .empty-state {
    text-align: center;
    padding: 3rem 1rem;
    color: var(--text-muted);
    font-size: 1rem;
  }

  @media (max-width: 768px) {
    .hero {
      padding: 56px 0 32px;
    }

    .hero-title {
      font-size: 2rem;
    }

    .hero-subtitle {
      font-size: 0.95rem;
    }

    .stat-number {
      font-size: 2rem;
    }

    .search-bar {
      flex-wrap: wrap;
    }

    .search-btn {
      width: 100%;
      justify-content: center;
    }
  }

  @media (max-width: 600px) {
    .hero {
      padding: 40px 0 24px;
    }

    .hero-title {
      font-size: 1.75rem;
    }
  }
</style>

<script>
  async function apiFetch(path, method = 'GET', body = null) {
    const opts = {
      method,
      headers: {
        'Content-Type': 'application/json'
      }
    };
    if (body) opts.body = JSON.stringify(body);
    const res = await fetch(path, opts);
    return res;
  }

  let currentSort = { column: null, asc: true };
  let currentFilter = 'all';
  let currentSearch = '';

  function applyFiltersAndSort() {
    const rows = Array.from(document.querySelectorAll('.alias-row'));
    rows.forEach(row => {
      const matchesFilter = currentFilter === 'all' || row.dataset.status === currentFilter;
      const matchesSearch = !currentSearch || row.dataset.address.toLowerCase().includes(currentSearch.toLowerCase());
      row.style.display = (matchesFilter && matchesSearch) ? '' : 'none';
    });
    if (currentSort.column) {
      sortTable(currentSort.column, currentSort.asc);
    }
  }

  document.querySelectorAll('.pill[data-filter]').forEach(pill => {
    pill.addEventListener('click', () => {
      document.querySelectorAll('.pill[data-filter]').forEach(p => p.classList.remove('active'));
      pill.classList.add('active');
      currentFilter = pill.dataset.filter;
      applyFiltersAndSort();
    });
  });

  const searchInput = document.getElementById('alias-search');
  searchInput.addEventListener('input', (e) => {
    currentSearch = e.target.value;
    applyFiltersAndSort();
  });

  function sortTable(column, asc) {
    const tbody = document.getElementById('alias-tbody');
    const rows = Array.from(tbody.querySelectorAll('.alias-row'));
    
    rows.sort((a, b) => {
      let valA, valB;
      switch (column) {
        case 'address':
          valA = a.dataset.address.toLowerCase();
          valB = b.dataset.address.toLowerCase();
          break;
        case 'first_seen':
          valA = parseInt(a.dataset.firstSeen, 10);
          valB = parseInt(b.dataset.firstSeen, 10);
          break;
        case 'last_seen':
          valA = parseInt(a.dataset.lastSeen, 10);
          valB = parseInt(b.dataset.lastSeen, 10);
          break;
        case 'mail_count':
          valA = parseInt(a.dataset.mailCount, 10);
          valB = parseInt(b.dataset.mailCount, 10);
          break;
        case 'status':
          valA = a.dataset.status;
          valB = b.dataset.status;
          break;
        default:
          return 0;
      }
      if (typeof valA === 'string') {
        return asc ? valA.localeCompare(valB) : valB.localeCompare(valA);
      }
      return asc ? valA - valB : valB - valA;
    });

    rows.forEach(row => tbody.appendChild(row));
  }

  document.querySelectorAll('th.sortable').forEach(th => {
    th.addEventListener('click', () => {
      const column = th.dataset.sort;
      document.querySelectorAll('th.sortable').forEach(h => h.classList.remove('sort-asc', 'sort-desc'));
      
      if (currentSort.column === column) {
        currentSort.asc = !currentSort.asc;
      } else {
        currentSort.column = column;
        currentSort.asc = true;
      }
      
      th.classList.add(currentSort.asc ? 'sort-asc' : 'sort-desc');
      sortTable(column, currentSort.asc);
    });
  });

  function attachToggleListeners() {
    document.querySelectorAll('.btn-toggle').forEach(btn => {
      btn.removeEventListener('click', handleToggle);
      btn.addEventListener('click', handleToggle);
    });
  }

  async function handleToggle(e) {
    const btn = e.currentTarget;
    const address = btn.dataset.address;
    const currentStatus = btn.dataset.status;
    const newStatus = currentStatus === 'active' ? 'blocked' : 'active';

    btn.disabled = true;
    btn.textContent = '...';

    const res = await apiFetch(
      `/api/aliases/${encodeURIComponent(address)}`,
      'PATCH',
      { status: newStatus }
    );

    if (res.ok) {
      const row = document.querySelector(`tr[data-address="${address}"]`);
      row.dataset.status = newStatus;
      btn.dataset.status = newStatus;
      btn.textContent = newStatus === 'active' ? 'Disable' : 'Enable';
      const badge = row.querySelector('.badge');
      badge.className = `badge ${newStatus === 'active' ? 'badge-active' : 'badge-blocked'}`;
      badge.textContent = newStatus;
    } else {
      btn.textContent = currentStatus === 'active' ? 'Disable' : 'Enable';
      alert('Failed to update alias.');
    }
    btn.disabled = false;
  }

  function attachDeleteListeners() {
    document.querySelectorAll('.btn-delete').forEach(btn => {
      btn.removeEventListener('click', handleDelete);
      btn.addEventListener('click', handleDelete);
    });
  }

  async function handleDelete(e) {
    const btn = e.currentTarget;
    const address = btn.dataset.address;
    if (!confirm(`Delete ${address}? This cannot be undone.`)) return;

    btn.disabled = true;
    const res = await apiFetch(
      `/api/aliases/${encodeURIComponent(address)}`,
      'DELETE'
    );

    if (res.ok) {
      document.querySelector(`tr[data-address="${address}"]`)?.remove();
    } else {
      alert('Failed to delete alias.');
      btn.disabled = false;
    }
  }

  attachToggleListeners();
  attachDeleteListeners();
</script>
